# ============================================================
# Geordie Miner — .gitignore
# ============================================================

# ---- Analysis output (regenerated on every run) ----
# The script writes to analyis_<dataset>/ (note original spelling).
# Match both the typo'd and corrected forms.
analyis_*/
analysis_*/
py-text-mining/analyis_*/
py-text-mining/analysis_*/

# ---- Input data (academic papers / PDFs) ----
# Likely copyrighted journal articles — keep out of the repo by default.
# Remove these lines (or use `git add -f`) if you want to track a corpus.
data_*/
py-text-mining/data_*/

# ---- NLTK data (downloaded on first run) ----
_nltk_data/
py-text-mining/_nltk_data/

# ---- Logs and captured terminal output ----
*.log
output.txt

# ---- Python ----
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Virtual environments
.venv/
venv/
env/
ENV/
.env

# Jupyter
.ipynb_checkpoints/
*.ipynb_checkpoints

# pytest / coverage
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/

# Type checkers
.mypy_cache/
.pyre/
.pytype/

# ---- IDE / editor ----
.idea/
.vscode/
*.swp
*.swo
*~

# ---- OS cruft ----
.DS_Store
Thumbs.db
Desktop.ini
ehthumbs.db

# ---- Windows shortcuts ----
*.lnk
