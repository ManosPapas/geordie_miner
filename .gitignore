# ============================================================
# Geordie Miner — .gitignore
# ============================================================

# ---- Input data (likely copyrighted journal articles) ----
# Drop your corpus(es) into data/<name>/ — they stay local.
data/*
!data/README.md

# ---- Analysis output (regenerated on every run) ----
output/*
!output/README.md

# ---- Caches (auto-downloaded NLTK resources, etc) ----
.cache/
_nltk_data/    # historical name

# ---- Temp files generated by notebooks ----
config/_demo_config.txt

# ---- Logs and captured terminal output ----
*.log
output.txt

# ---- Python ----
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# ---- Virtual environments ----
.venv/
venv/
env/
ENV/
.env

# ---- Jupyter ----
.ipynb_checkpoints/
*.ipynb_checkpoints

# ---- Tooling caches ----
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
.mypy_cache/
.pyre/
.pytype/
.ruff_cache/

# ---- IDE / editor ----
.idea/
.vscode/
*.swp
*.swo
*~

# ---- OS cruft ----
.DS_Store
Thumbs.db
Desktop.ini
ehthumbs.db

# ---- Windows shortcuts ----
*.lnk

# ---- Claude Code local state ----
.claude/
