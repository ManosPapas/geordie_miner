# ============================================================
# Geordie Miner — .gitignore
# ============================================================

# ---- Input data (likely copyrighted journal articles) ----
# Keep the folder, ignore its contents. Drop your corpus(es) into data/<name>/.
# Remove these lines (or use `git add -f`) if you want to track a corpus.
data/*
!data/.gitkeep

# ---- Analysis output (regenerated on every run) ----
output/*
!output/.gitkeep

# ---- NLTK data (downloaded on first run) ----
_nltk_data/

# ---- Logs and captured terminal output ----
*.log
output.txt
comparison_report.md

# ---- Python ----
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# ---- Virtual environments ----
.venv/
venv/
env/
ENV/
.env

# ---- Jupyter ----
.ipynb_checkpoints/
*.ipynb_checkpoints

# ---- Tooling caches ----
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
.mypy_cache/
.pyre/
.pytype/
.ruff_cache/

# ---- IDE / editor ----
.idea/
.vscode/
*.swp
*.swo
*~

# ---- OS cruft ----
.DS_Store
Thumbs.db
Desktop.ini
ehthumbs.db

# ---- Windows shortcuts ----
*.lnk

# ---- Claude Code local state ----
.claude/
